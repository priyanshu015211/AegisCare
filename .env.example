# ============================================================
# AegisCare Environment Configuration
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
APP_ENV=development                  # development | staging | production
APP_NAME=AegisCare
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR

# ------------------------------------------------------------
# Backend (FastAPI)
# ------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=1                    # Increase in production
SECRET_KEY=changeme_use_a_long_random_string_here
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000

# ------------------------------------------------------------
# Frontend (Streamlit)
# ------------------------------------------------------------
STREAMLIT_PORT=8501
BACKEND_URL=http://localhost:8000

# ------------------------------------------------------------
# Supabase
# ------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ------------------------------------------------------------
# AI Models
# ------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key  # Optional fallback
PRIMARY_LLM=gemini                   # gemini | openai
GEMINI_MODEL=gemini-1.5-flash
OPENAI_MODEL=gpt-4o-mini

# LLM Behavior
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.3
LLM_TIMEOUT_SECONDS=30

# ------------------------------------------------------------
# Voice Pipeline
# ------------------------------------------------------------
WHISPER_MODEL_SIZE=base              # tiny | base | small | medium | large
WHISPER_DEVICE=cpu                   # cpu | cuda
WHISPER_COMPUTE_TYPE=int8
TTS_ENGINE=xtts                      # xtts | piper
TTS_MODEL_PATH=./voice_pipeline/tts/models/
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1

# ------------------------------------------------------------
# Agora (Video Consultation)
# ------------------------------------------------------------
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate
AGORA_TOKEN_EXPIRY_SECONDS=3600

# ------------------------------------------------------------
# Emergency Escalation Engine
# ------------------------------------------------------------
ESCALATION_GREEN_THRESHOLD=30        # Risk score 0-30 = GREEN
ESCALATION_YELLOW_THRESHOLD=60       # Risk score 31-60 = YELLOW
ESCALATION_RED_THRESHOLD=61          # Risk score 61+ = RED
ESCALATION_CRITICAL_THRESHOLD=85     # Auto-alert at this score

# ------------------------------------------------------------
# Hospital Load Balancing
# ------------------------------------------------------------
MAX_HOSPITAL_CAPACITY=100
HIGH_LOAD_THRESHOLD=80               # Percent of capacity
CRITICAL_LOAD_THRESHOLD=95

# ------------------------------------------------------------
# Appointment Scheduling
# ------------------------------------------------------------
DEFAULT_APPOINTMENT_DURATION_MINUTES=15
MAX_ADVANCE_BOOKING_DAYS=30
SLOT_INTERVAL_MINUTES=15

# ------------------------------------------------------------
# Session / Memory
# ------------------------------------------------------------
SESSION_EXPIRY_HOURS=24
PATIENT_MEMORY_MAX_TURNS=20          # Max turns before summarization
MEMORY_SUMMARY_TRIGGER=15            # Summarize after N turns

# ------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=20

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
LOG_FILE=logs/aegiscare.log
LOG_ROTATION=10 MB
LOG_RETENTION=30 days
